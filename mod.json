{
    "geode": "5.5.3",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "id": "mopigames.exponential-volume",
    "name": "Exponential Volume",
    "version": "v1.0.1",
    "developer": "Mopigames",
    "description": "Makes the Music and SFX volume sliders exponential instead of linear, giving much more control at low volumes.",
    "tags": ["enhancement", "music", "customization"],
    "dependencies": {
        "geode.node-ids": ">=1.0.0"
    },
    "settings": {
        "exponent": {
            "type": "float",
            "default": 3.0,
            "min": 1.0,
            "max": 5.0,
            "name": "Exponent",
            "description": "Controls the curve steepness. Higher = more precision at low volumes. 1.0 = linear (vanilla)."
        },
        "logging": {
            "type": "bool",
            "default": false,
            "name": "Enable Logging",
            "description": "Enable logging for debugging."
        }
    }
}
